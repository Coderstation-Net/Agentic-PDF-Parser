    {
      "question": "How many hours/week within office hours, after office hours on a scheduled workday, on a rest day or scheduled day off, holiday, or special non-working day is considered a normal teaching load?",
      "answer": "A faculty member's normal teaching load is 30 hours/week within office hours, after office hours on a scheduled workday, on a rest day or scheduled day off, holiday, or special non-working day."
    },
    {
      "question": "What is the criteria for determining a faculty member's performance and accomplishments?",
      "answer": "A faculty member's performance and accomplishments are comparable to at least an Assistant Professor I rank."
    },
    {
      "question": "How is a faculty member's degree program aligned/allied to their field of specialization determined?",
      "answer": "A faculty member's degree program aligned/allied to their field of specialization is determined by their units earned."
    },
    {
      "question": "What is the policy on honorarium/overtime pay for teaching overload?",
      "answer": "The faculty member is entitled to an honorarium/overtime pay for the teaching overload subject to the availability of funds."
    },
    {
      "question": "How many rest days or scheduled day off are considered normal?",
      "answer": "A faculty member's normal rest days or scheduled day off are two (2) days per week."
    },
    {
      "question": "What is the policy on service credit equivalence?",
      "answer": "Service credit equivalence is granted to a faculty member who has rendered at least three (3) years of continuous and satisfactory service in their current rank."
    },
    {
      "question": "How many hours/week within office hours, after office hours on a scheduled workday, on a rest day or scheduled day off, holiday, or special non-working day is considered a maximum teaching load?",
      "answer": "A faculty member's maximum teaching load is 40 hours/week within office hours, after office hours on a scheduled workday, on a rest day or scheduled day off, holiday, or special non-working day."
